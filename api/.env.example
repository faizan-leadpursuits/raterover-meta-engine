# ═══════════════════════════════════════════════════════════════
# Hotel Metasearch API — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values

# ── ScraperFlow Lambda ──
SCRAPERFLOW_LAMBDA=scraperflow-engine-dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# ── API Authentication ──
# Set to "true" to require API key on all requests
REQUIRE_AUTH=false
# Comma-separated list of valid API keys
API_KEYS=
# RapidAPI proxy secret (if hosted on RapidAPI)
RAPIDAPI_PROXY_SECRET=

# ── Server ──
HOST=0.0.0.0
PORT=8000
DEV_MODE=true
LOG_LEVEL=INFO

# ── Proxy (DataImpulse residential proxy for Lambda payloads) ──
PROXY_URL=http://31fbbc246b2c66370760:72cf4e8ccb06847d@gw.dataimpulse.com:823

# ── Timeouts ──
# Max seconds to wait for a single provider Lambda invocation
PROVIDER_TIMEOUT=60
# Max seconds for the entire search across all providers
SEARCH_TIMEOUT=90
# Max concurrent Lambda invocations
MAX_CONCURRENT=10
